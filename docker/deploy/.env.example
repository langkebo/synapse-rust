# Synapse-Rust 环境变量配置
# 复制此文件为 .env 并填入实际值

# ===== 服务器配置 =====
SERVER_NAME=localhost
PUBLIC_BASEURL=http://localhost:8008

# ===== 数据库配置 =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=synapse

# ===== Redis 配置 =====
REDIS_PASSWORD=CHANGE_ME

# ===== 安全密钥（必须修改）=====
# 生成方法: openssl rand -base64 32
ADMIN_SHARED_SECRET=CHANGE_ME
JWT_SECRET=CHANGE_ME
REGISTRATION_SHARED_SECRET=CHANGE_ME
SECRET_KEY=CHANGE_ME
MACAROON_SECRET=CHANGE_ME
FORM_SECRET=CHANGE_ME

# ===== 镜像配置 =====
SYNAPSE_IMAGE=vmuser232922/mysynapse:latest

# ===== 端口配置 =====
SYNAPSE_PORT=8008
HTTP_PORT=80
HTTPS_PORT=443
FEDERATION_PORT=8448
PROMETHEUS_PORT=9090

# ===== 资源限制 =====
POSTGRES_CPU_LIMIT=1.5
POSTGRES_MEMORY_LIMIT=1536m
REDIS_CPU_LIMIT=1.0
REDIS_MEMORY_LIMIT=512m
SYNAPSE_CPU_LIMIT=2.0
SYNAPSE_MEMORY_LIMIT=2048m
NGINX_CPU_LIMIT=0.5
NGINX_MEMORY_LIMIT=256m
