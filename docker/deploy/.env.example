# =============================================================================
# synapse-rust docker/deploy 环境变量模板
# =============================================================================
# 复制为 .env 后修改。deploy.sh 会自动补齐占位符密钥。
# =============================================================================

# -----------------------------------------------------------------------------
# 基础部署
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=synapse
TZ=UTC

# -----------------------------------------------------------------------------
# 服务器配置 (必须修改)
# -----------------------------------------------------------------------------
SERVER_NAME=matrix.example.com
PUBLIC_BASEURL=https://matrix.example.com

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__REQUIRED_SET_POSTGRES_PASSWORD__
POSTGRES_DB=synapse
POSTGRES_PORT=5432
POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=C --lc-ctype=C
SYNAPSE__DATABASE__POOL_SIZE=20
SYNAPSE__DATABASE__MAX_SIZE=50
SYNAPSE__DATABASE__MIN_IDLE=10
SYNAPSE__DATABASE__CONNECTION_TIMEOUT=60
POSTGRES_CPU_LIMIT=1.5
POSTGRES_MEMORY_LIMIT=1536m
POSTGRES_PIDS_LIMIT=256

# -----------------------------------------------------------------------------
# Redis 配置
# -----------------------------------------------------------------------------
REDIS_PASSWORD=__REQUIRED_SET_REDIS_PASSWORD__
REDIS_PORT=6379
REDIS_KEY_PREFIX=synapse:
REDIS_MAX_MEMORY=256mb
REDIS_EVICTION_POLICY=allkeys-lru
REDIS_CPU_LIMIT=1.0
REDIS_MEMORY_LIMIT=512m
REDIS_PIDS_LIMIT=128

# -----------------------------------------------------------------------------
# 应用安全与认证
# -----------------------------------------------------------------------------
ADMIN_SHARED_SECRET=__REQUIRED_SET_ADMIN_SHARED_SECRET__
JWT_SECRET=__REQUIRED_SET_JWT_SECRET__
REGISTRATION_SHARED_SECRET=__REQUIRED_SET_REGISTRATION_SHARED_SECRET__
SECRET_KEY=__REQUIRED_SET_SECRET_KEY__
MACAROON_SECRET=__REQUIRED_SET_MACAROON_SECRET__
FORM_SECRET=__REQUIRED_SET_FORM_SECRET__

# -----------------------------------------------------------------------------
# Synapse / 容器运行
# -----------------------------------------------------------------------------
SYNAPSE_PORT=8008
FEDERATION_PORT=8448
HTTP_PORT=80
HTTPS_PORT=443
PROMETHEUS_PORT=9090
RUST_LOG=info
HEALTHCHECK_RETRIES=30
HEALTHCHECK_INTERVAL=5
ROLLBACK_ON_FAILURE=true
ALLOWED_ORIGINS=http://localhost:28008,http://127.0.0.1:28008,http://localhost:28080,http://127.0.0.1:28080,https://localhost:28443,https://127.0.0.1:28443
CORS_ORIGIN_PATTERN=^https?://(localhost|127\\.0\\.0\\.1)(:[0-9]+)?$
SYNAPSE_CPU_LIMIT=2.0
SYNAPSE_MEMORY_LIMIT=2048m
SYNAPSE_PIDS_LIMIT=512
MIGRATOR_CPU_LIMIT=1.0
MIGRATOR_MEMORY_LIMIT=1024m
MIGRATOR_PIDS_LIMIT=128
NGINX_CPU_LIMIT=0.5
NGINX_MEMORY_LIMIT=256m
NGINX_PIDS_LIMIT=128

# -----------------------------------------------------------------------------
# SSL/TLS 配置
# -----------------------------------------------------------------------------
ENABLE_SSL=false
SSL_CERT=cert.pem
SSL_KEY=key.pem
