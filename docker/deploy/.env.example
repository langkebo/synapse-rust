# =============================================================================
# 环境变量配置文件
# =============================================================================
# 复制此文件为 .env 并根据实际环境修改配置
# 运行 ./deploy.sh 时会自动生成安全密钥
# =============================================================================

# -----------------------------------------------------------------------------
# 服务器配置 (必须修改)
# -----------------------------------------------------------------------------
# Matrix 服务器名称 (例如: matrix.example.com)
SERVER_NAME=your-server-name.com

# 公开访问 URL (例如: https://matrix.example.com)
PUBLIC_BASEURL=https://matrix.example.com

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
# 运行 deploy.sh 时自动生成安全密码
POSTGRES_PASSWORD=__REQUIRED_SET_POSTGRES_PASSWORD__
POSTGRES_DB=synapse
POSTGRES_PORT=5432
SYNAPSE__DATABASE__POOL_SIZE=20
SYNAPSE__DATABASE__MAX_SIZE=50
SYNAPSE__DATABASE__MIN_IDLE=10
SYNAPSE__DATABASE__CONNECTION_TIMEOUT=60
POSTGRES_CPU_LIMIT=1.5
POSTGRES_MEMORY_LIMIT=1536m
POSTGRES_PIDS_LIMIT=256

# -----------------------------------------------------------------------------
# Redis 配置
# -----------------------------------------------------------------------------
REDIS_PASSWORD=__REQUIRED_SET_REDIS_PASSWORD__
REDIS_PORT=6379
REDIS_CPU_LIMIT=1.0
REDIS_MEMORY_LIMIT=512m
REDIS_PIDS_LIMIT=128

# -----------------------------------------------------------------------------
# Synapse 配置
# -----------------------------------------------------------------------------
SYNAPSE_PORT=8008

# 联邦端口 (Matrix 服务器间通信)
FEDERATION_PORT=8448
SYNAPSE_CPU_LIMIT=2.0
SYNAPSE_MEMORY_LIMIT=2048m
SYNAPSE_PIDS_LIMIT=512
MIGRATOR_CPU_LIMIT=1.0
MIGRATOR_MEMORY_LIMIT=1024m
MIGRATOR_PIDS_LIMIT=128

# 管理员共享密钥 (运行 deploy.sh 自动生成)
ADMIN_SHARED_SECRET=__REQUIRED_SET_ADMIN_SHARED_SECRET__

# JWT 签名密钥 (运行 deploy.sh 自动生成)
JWT_SECRET=__REQUIRED_SET_JWT_SECRET__

# 注册共享密钥 (运行 deploy.sh 自动生成)
REGISTRATION_SHARED_SECRET=__REQUIRED_SET_REGISTRATION_SHARED_SECRET__

# -----------------------------------------------------------------------------
# Nginx 配置
# -----------------------------------------------------------------------------
HTTP_PORT=80
HTTPS_PORT=443
NGINX_CPU_LIMIT=0.5
NGINX_MEMORY_LIMIT=256m
NGINX_PIDS_LIMIT=128

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
RUST_LOG=info

# -----------------------------------------------------------------------------
# SSL/TLS 配置 (可选)
# -----------------------------------------------------------------------------
# 启用 HTTPS
ENABLE_SSL=false

# SSL 证书路径 (相对于 ssl 目录)
SSL_CERT=cert.pem
SSL_KEY=key.pem
