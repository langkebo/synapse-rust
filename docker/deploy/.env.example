# =============================================================================
# 环境变量配置文件
# =============================================================================
# 复制此文件为 .env 并根据实际环境修改配置
# 运行 ./deploy.sh 时会自动生成安全密钥
# =============================================================================

# -----------------------------------------------------------------------------
# 服务器配置 (必须修改)
# -----------------------------------------------------------------------------
# Matrix 服务器名称 (例如: matrix.example.com)
SERVER_NAME=your-server-name.com

# 公开访问 URL (例如: https://matrix.example.com)
PUBLIC_BASEURL=https://matrix.example.com

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
# 运行 deploy.sh 时自动生成安全密码
POSTGRES_PASSWORD=""
POSTGRES_DB=synapse
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis 配置
# -----------------------------------------------------------------------------
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Synapse 配置
# -----------------------------------------------------------------------------
SYNAPSE_PORT=8008

# 联邦端口 (Matrix 服务器间通信)
FEDERATION_PORT=8448

# 管理员共享密钥 (运行 deploy.sh 自动生成)
ADMIN_SHARED_SECRET=""

# JWT 签名密钥 (运行 deploy.sh 自动生成)
JWT_SECRET=""

# 注册共享密钥 (运行 deploy.sh 自动生成)
REGISTRATION_SHARED_SECRET=""

# -----------------------------------------------------------------------------
# Nginx 配置
# -----------------------------------------------------------------------------
HTTP_PORT=80
HTTPS_PORT=443

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
RUST_LOG=info

# -----------------------------------------------------------------------------
# SSL/TLS 配置 (可选)
# -----------------------------------------------------------------------------
# 启用 HTTPS
ENABLE_SSL=false

# SSL 证书路径 (相对于 ssl 目录)
SSL_CERT=cert.pem
SSL_KEY=key.pem
