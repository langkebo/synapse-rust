# =============================================================================
# Synapse-Rust 生产部署环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入实际值
# 生成密钥: ./scripts/generate-secrets.sh
# =============================================================================

# ===== 项目标识 =====
COMPOSE_PROJECT_NAME=synapse

# ===== 服务器配置 =====
SERVER_NAME=matrix.test
PUBLIC_BASEURL=https://matrix.test

# ===== CORS 配置 =====
ALLOWED_ORIGINS=http://localhost:8008,http://127.0.0.1:8008,http://localhost:6130,http://127.0.0.1:6130,http://localhost:8080,http://127.0.0.1:8080,https://localhost:8443,https://127.0.0.1:8443,https://element.test,https://matrix.test,tauri://localhost,https://tauri.localhost,vector://vector
CORS_ORIGIN_PATTERN=^https?://(localhost|127\\.0\\.0\\.1|element\\.test|matrix\\.test)(:[0-9]+)?$

# ===== 数据库配置 =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=synapse

# ===== Redis 配置 =====
REDIS_PASSWORD=CHANGE_ME
REDIS_MAX_MEMORY=256mb
REDIS_EVICTION_POLICY=allkeys-lru
REDIS_KEY_PREFIX=synapse:

# ===== 安全密钥（必须修改）=====
# 生成方法: openssl rand -base64 32
ADMIN_SHARED_SECRET=CHANGE_ME
JWT_SECRET=CHANGE_ME
REGISTRATION_SHARED_SECRET=CHANGE_ME
SECRET_KEY=CHANGE_ME
MACAROON_SECRET=CHANGE_ME
FORM_SECRET=CHANGE_ME
FEDERATION_SIGNING_KEY=CHANGE_ME
FEDERATION_KEY_ID=ed25519:auto
WORKER_REPLICATION_SECRET=CHANGE_ME

# ===== 镜像配置 =====
# 本地构建: synapse-rust:local
# 远程镜像: vmuser232922/mysynapse:latest
SYNAPSE_IMAGE=synapse-rust:local
SYNAPSE_PULL_POLICY=never

# ===== 端口配置 =====
SYNAPSE_PORT=8008
HTTP_PORT=80
HTTPS_PORT=443
FEDERATION_PORT=8448
PROMETHEUS_PORT=9090

# ===== 资源限制 =====
POSTGRES_CPU_LIMIT=1.5
POSTGRES_MEMORY_LIMIT=1536m
POSTGRES_PIDS_LIMIT=256
REDIS_CPU_LIMIT=1.0
REDIS_MEMORY_LIMIT=512m
REDIS_PIDS_LIMIT=128
SYNAPSE_CPU_LIMIT=2.0
SYNAPSE_MEMORY_LIMIT=2048m
SYNAPSE_PIDS_LIMIT=512
NGINX_CPU_LIMIT=0.5
NGINX_MEMORY_LIMIT=256m
NGINX_PIDS_LIMIT=128
MIGRATOR_CPU_LIMIT=1.0
MIGRATOR_MEMORY_LIMIT=1024m
MIGRATOR_PIDS_LIMIT=128

# ===== 数据库连接池 =====
SYNAPSE__DATABASE__POOL_SIZE=20
SYNAPSE__DATABASE__MAX_SIZE=50
SYNAPSE__DATABASE__MIN_IDLE=10
SYNAPSE__DATABASE__CONNECTION_TIMEOUT=60

# ===== 数据库迁移 =====
RUN_MIGRATIONS=false
ENABLED_EXTENSIONS=all
SYNAPSE_ENABLE_RUNTIME_DB_INIT=false
ROLLBACK_ON_FAILURE=true

# ===== SSL 配置 =====
# 证书和私钥的文件名（放在 ssl/ 目录下）
SSL_CERT=cert.pem
SSL_KEY=key.pem

# ===== 监控 =====
OTLP_ENDPOINT=http://127.0.0.1:4317

# ===== 其他 =====
RUST_LOG=info
TZ=UTC
SYNAPSE_MEGOLM_ENCRYPTION_KEY_PATH=/app/data/megolm.key
HEALTHCHECK_RETRIES=30
HEALTHCHECK_INTERVAL=5
