COMPOSE_PROJECT_NAME=synapse
SYNAPSE_IMAGE=synapse-rust
SYNAPSE_TOOLS_IMAGE=synapse-rust-tools
SYNAPSE_IMAGE_TAG=latest
POSTGRES_VERSION=16
REDIS_VERSION=7
TZ=UTC
RUST_LOG=info

SYNAPSE_PORT=28008
FEDERATION_PORT=28448
PROMETHEUS_PORT=29090
DB_EXPOSE_PORT=5432
REDIS_EXPOSE_PORT=6379

SERVER_NAME=localhost
PUBLIC_BASEURL=http://localhost:28008
ALLOWED_ORIGINS=http://localhost:28008,http://127.0.0.1:28008

DB_USER=synapse
DB_PASSWORD=replace_with_secure_password
DB_NAME=synapse
DB_POOL_SIZE=20
DB_MAX_SIZE=50
DB_MIN_IDLE=10
DB_CONNECTION_TIMEOUT=60

REDIS_KEY_PREFIX=synapse:

SECRET_KEY=replace_with_secure_secret
MACAROON_SECRET=replace_with_secure_secret
FORM_SECRET=replace_with_secure_secret
REGISTRATION_SECRET=replace_with_secure_secret
ADMIN_SECRET=replace_with_secure_secret
WORKER_REPLICATION_SECRET=replace_with_secure_secret
FEDERATION_SIGNING_KEY=replace_with_secure_secret
FEDERATION_KEY_ID=ed25519:local
OTLP_ENDPOINT=http://otel-collector:4317

RUN_MIGRATIONS=true
VERIFY_SCHEMA=true
STOP_ON_MIGRATION_FAILURE=true
DB_WAIT_ATTEMPTS=30
DB_WAIT_INTERVAL=2
MIGRATION_TIMEOUT=300
SYNAPSE_ENABLE_RUNTIME_DB_INIT=false
COSIGN_KEY=
COSIGN_PASSWORD=
COSIGN_EXPERIMENTAL=false
