# ============================================================================
# Synapse Rust 环境变量配置模板
# ============================================================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# 
# 环境区分:
# - SYNAPSE_ENV=development  开发环境
# - SYNAPSE_ENV=production   生产环境 (默认)
# ============================================================================

# ============================================================================
# 环境标识
# ============================================================================
SYNAPSE_ENV=production

# ============================================================================
# 服务器基础配置
# ============================================================================
SERVER_NAME=cjystx.top
SERVER_HOST=0.0.0.0
SERVER_PORT=8008
PUBLIC_BASEURL=https://matrix.cjystx.top

# ============================================================================
# 安全密钥 (必须设置 - 生产环境禁止使用默认值)
# ============================================================================
# Macaroon 密钥 - 用于生成访问令牌 (至少32字符)
MACAROON_SECRET=your_macaroon_secret_key_here_min_32_chars

# 表单密钥 - 用于表单验证 (至少32字符)
FORM_SECRET=your_form_secret_key_here_min_32_chars

# 注册共享密钥
REGISTRATION_SECRET=your_registration_secret_here

# JWT 签名密钥 (至少32字符)
SECRET_KEY=your_jwt_secret_key_here_min_32_chars

# 管理员注册密钥
ADMIN_SECRET=your_admin_secret_here

# ============================================================================
# 签名密钥路径
# ============================================================================
SIGNING_KEY_PATH=/app/data/cjystx.top.signing.key

# ============================================================================
# 联邦配置
# ============================================================================
FEDERATION_ENABLED=true
FEDERATION_ALLOW_INGRESS=true
FEDERATION_PORT=8448
FEDERATION_POOL_SIZE=10
FEDERATION_MAX_PAYLOAD=100000

# 联邦签名密钥 (Base64 编码)
FEDERATION_SIGNING_KEY=your_federation_signing_key_base64
FEDERATION_KEY_ID=ed25519:testkb1OUw

# ============================================================================
# 数据库配置
# ============================================================================
DB_HOST=synapse-postgres
DB_PORT=5432
DB_USER=synapse
DB_PASSWORD=your_secure_db_password_here
DB_NAME=synapse_test

# 连接池
DB_POOL_SIZE=20
DB_MAX_POOL_SIZE=50
DB_MIN_IDLE=10
DB_CONNECTION_TIMEOUT=60

# ============================================================================
# Redis 配置
# ============================================================================
REDIS_HOST=synapse-redis
REDIS_PORT=6379
REDIS_KEY_PREFIX=synapse:cjystx.top:
REDIS_POOL_SIZE=20
REDIS_ENABLED=false

# ============================================================================
# 日志配置
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=/app/logs/synapse.log
LOG_DIR=/app/logs

# ============================================================================
# 注册配置
# ============================================================================
ENABLE_REGISTRATION=true
ENABLE_REGISTRATION_CAPTCHA=false

# ============================================================================
# Token 过期配置 (秒)
# ============================================================================
EXPIRE_ACCESS_TOKEN=true
EXPIRE_ACCESS_TOKEN_LIFETIME=7200
REFRESH_TOKEN_LIFETIME=1209600
REFRESH_TOKEN_SLIDING_WINDOW_SIZE=2000
SESSION_DURATION=172800

# ============================================================================
# 限流配置
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_SECOND=20
RATE_LIMIT_BURST_SIZE=40
RATE_LIMIT_FAIL_OPEN=false

# ============================================================================
# URL 预览配置
# ============================================================================
URL_PREVIEW_ENABLED=true
URL_PREVIEW_SPIDER_ENABLED=true
URL_PREVIEW_OEMBED_ENABLED=false
URL_PREVIEW_MAX_SIZE=10M
URL_PREVIEW_CACHE_DURATION=86400
URL_PREVIEW_TIMEOUT=10
URL_PREVIEW_MAX_REDIRECTS=5

# ============================================================================
# CORS 配置
# ============================================================================
CORS_ALLOWED_ORIGIN_1=*
CORS_ALLOWED_ORIGIN_2=https://cjystx.top
CORS_ALLOWED_ORIGIN_3=https://matrix.cjystx.top
CORS_ALLOWED_ORIGIN_4=https://element.cjystx.top
CORS_MAX_AGE=172800

# ============================================================================
# SMTP 邮件配置
# ============================================================================
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Matrix <noreply@cjystx.top>
SMTP_TLS=true
SMTP_TOKEN_EXPIRE=1800
SMTP_RATE_LIMIT_PER_MINUTE=5
SMTP_RATE_LIMIT_PER_HOUR=20

# ============================================================================
# VoIP/TURN 配置
# ============================================================================
TURN_URI_1=turn:turn.cjystx.top:3478?transport=udp
TURN_URI_2=turn:turn.cjystx.top:3478?transport=tcp
TURN_SECRET=
TURN_LIFETIME=1h
TURN_ALLOW_GUESTS=true

# ============================================================================
# 推送通知配置
# ============================================================================
PUSH_ENABLED=false
PUSH_RETRY_COUNT=3
PUSH_TIMEOUT=10

# ============================================================================
# OIDC 单点登录配置
# ============================================================================
OIDC_ENABLED=false
OIDC_ISSUER=https://auth.cjystx.top
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ALLOW_EXISTING_USERS=true
OIDC_BLOCK_UNKNOWN_USERS=false
OIDC_TIMEOUT=10

# ============================================================================
# SAML 单点登录配置
# ============================================================================
SAML_ENABLED=false
SAML_SP_ENTITY_ID=https://matrix.cjystx.top
SAML_ALLOW_EXISTING_USERS=true
SAML_BLOCK_UNKNOWN_USERS=false
SAML_SIGN_REQUESTS=false
SAML_WANT_RESPONSE_SIGNED=true
SAML_WANT_ASSERTIONS_SIGNED=true
SAML_SESSION_LIFETIME=28800
SAML_TIMEOUT=10

# ============================================================================
# OpenTelemetry 配置
# ============================================================================
TELEMETRY_ENABLED=false
TELEMETRY_SERVICE_NAME=synapse-rust
TELEMETRY_SERVICE_VERSION=0.1.0
TELEMETRY_NAMESPACE=matrix
OTLP_ENDPOINT=http://otel-collector:4317
TELEMETRY_TRACE_ENABLED=true
TELEMETRY_METRICS_ENABLED=true
TELEMETRY_LOGS_ENABLED=false
TELEMETRY_SAMPLING_RATIO=0.1

# ============================================================================
# Jaeger 配置
# ============================================================================
JAEGER_ENABLED=false
JAEGER_AGENT_ENDPOINT=jaeger-agent:6831
JAEGER_COLLECTOR_ENDPOINT=http://jaeger-collector:14268/api/traces
JAEGER_SAMPLING_RATE=0.1

# ============================================================================
# Prometheus 配置
# ============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_PATH=/metrics
PROMETHEUS_INCLUDE_NAMESPACE=true

# ============================================================================
# 消息保留策略配置
# ============================================================================
RETENTION_ENABLED=false
RETENTION_MIN_LIFETIME=86400
RETENTION_MAX_LIFETIME=31536000

# ============================================================================
# 监听器配置
# ============================================================================
LISTENER_PORT=8008
LISTENER_BIND_ADDRESS=0.0.0.0
LISTENER_TLS=false

# ============================================================================
# Web 客户端配置
# ============================================================================
WEB_CLIENT_LOCATION=https://element.cjystx.top

# ============================================================================
# 其他配置
# ============================================================================
MAX_UPLOAD_SIZE=104857600
MAX_IMAGE_RESOLUTION=67108864
BACKGROUND_TASKS_INTERVAL=120
WARMUP_POOL=true
SERVE_SERVER_WELLKNOWN=true
