COMPOSE_PROJECT_NAME=synapse
SYNAPSE_IMAGE=synapse-rust
SYNAPSE_IMAGE_TAG=local
POSTGRES_VERSION=16
REDIS_VERSION=7
TZ=Asia/Shanghai
RUST_LOG=info
RUST_ENV=development

SYNAPSE_PORT=28008
FEDERATION_PORT=28448
DB_EXPOSE_PORT=5432
REDIS_EXPOSE_PORT=6379

SERVER_NAME=localhost
PUBLIC_BASEURL=http://localhost:28008
ALLOWED_ORIGINS=http://localhost:28008,http://127.0.0.1:28008,http://localhost:6130,http://127.0.0.1:6130

DB_USER=synapse
DB_PASSWORD=__REQUIRED_SET_DB_PASSWORD__
DB_NAME=synapse
DB_CPU_LIMIT=1.5
DB_MEMORY_LIMIT=1536m
DB_PIDS_LIMIT=256
DB_POOL_SIZE=20
DB_MAX_SIZE=50
DB_MIN_IDLE=10
DB_CONNECTION_TIMEOUT=60

REDIS_KEY_PREFIX=synapse:
REDIS_PASSWORD=__REQUIRED_SET_REDIS_PASSWORD__
REDIS_CPU_LIMIT=1.0
REDIS_MEMORY_LIMIT=512m
REDIS_PIDS_LIMIT=128

SYNAPSE_CPU_LIMIT=2.0
SYNAPSE_MEMORY_LIMIT=2048m
SYNAPSE_PIDS_LIMIT=512

SECRET_KEY=__REQUIRED_SET_SECRET_KEY__
MACAROON_SECRET=__REQUIRED_SET_MACAROON_SECRET__
FORM_SECRET=__REQUIRED_SET_FORM_SECRET__
REGISTRATION_SECRET=__REQUIRED_SET_REGISTRATION_SECRET__
ADMIN_SECRET=__REQUIRED_SET_ADMIN_SECRET__
ADMIN_REGISTRATION_SECRET=__REQUIRED_SET_ADMIN_REGISTRATION_SECRET__
TURN_PASSWORD=__REQUIRED_SET_TURN_PASSWORD__
OIDC_CLIENT_SECRET=__REQUIRED_SET_OIDC_CLIENT_SECRET__
OPENCLAW_AS_TOKEN=__REQUIRED_SET_OPENCLAW_AS_TOKEN__
OPENCLAW_HS_TOKEN=__REQUIRED_SET_OPENCLAW_HS_TOKEN__
FEDERATION_SIGNING_KEY=__REQUIRED_SET_FEDERATION_SIGNING_KEY__
FEDERATION_KEY_ID=ed25519:local

RUN_MIGRATIONS=true
VERIFY_SCHEMA=true
STOP_ON_MIGRATION_FAILURE=true
DB_WAIT_ATTEMPTS=30
DB_WAIT_INTERVAL=2
MIGRATION_TIMEOUT=300
SYNAPSE_ENABLE_RUNTIME_DB_INIT=false
