COMPOSE_PROJECT_NAME=synapse
SYNAPSE_IMAGE=synapse-rust
SYNAPSE_IMAGE_TAG=local
POSTGRES_VERSION=16
REDIS_VERSION=7
TZ=Asia/Shanghai
RUST_LOG=info
RUST_ENV=development

SYNAPSE_PORT=28008
FEDERATION_PORT=28448
DB_EXPOSE_PORT=5432
REDIS_EXPOSE_PORT=6379

SERVER_NAME=localhost
PUBLIC_BASEURL=http://localhost:28008
ALLOWED_ORIGINS=http://localhost:28008,http://127.0.0.1:28008,http://localhost:6130,http://127.0.0.1:6130

DB_USER=synapse
DB_PASSWORD=synapse
DB_NAME=synapse
DB_POOL_SIZE=20
DB_MAX_SIZE=50
DB_MIN_IDLE=10
DB_CONNECTION_TIMEOUT=60

REDIS_KEY_PREFIX=synapse:

SECRET_KEY=test_secret_key_which_is_long_enough_32_bytes_123456
MACAROON_SECRET=test_macaroon_secret_key_which_is_long_enough_32b
FORM_SECRET=test_form_secret_key_which_is_long_enough_32_bytes_123
REGISTRATION_SECRET=test_registration_secret_key_long_enough_32_b
ADMIN_SECRET=test_admin_shared_secret_not_default_20260403
FEDERATION_SIGNING_KEY=test_federation_signing_key_long_enough_32_bytes
FEDERATION_KEY_ID=ed25519:local

RUN_MIGRATIONS=true
VERIFY_SCHEMA=true
STOP_ON_MIGRATION_FAILURE=true
DB_WAIT_ATTEMPTS=30
DB_WAIT_INTERVAL=2
MIGRATION_TIMEOUT=300
SYNAPSE_ENABLE_RUNTIME_DB_INIT=false
