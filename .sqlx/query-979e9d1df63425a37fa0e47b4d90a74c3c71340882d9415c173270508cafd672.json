  "query": "\n            SELECT r.room_id, r.name, r.topic, r.avatar_url\n            FROM room_memberships rm\n            JOIN rooms r ON rm.room_id = r.room_id\n            WHERE rm.user_id = $1 AND rm.membership = 'join'\n            ORDER BY r.created_ts DESC\n            ",
