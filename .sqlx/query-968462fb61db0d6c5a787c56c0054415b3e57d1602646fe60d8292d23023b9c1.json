  "query": "SELECT id as \"id!\", room_id as \"room_id!\", root_event_id as \"root_event_id!\", sender as \"sender!\", thread_id, reply_count as \"reply_count!\",\n                       last_reply_event_id, last_reply_sender, last_reply_ts,\n                       participants, is_fetched as \"is_fetched!\", created_ts as \"created_ts!\", updated_ts\n                FROM thread_roots\n                WHERE room_id = $1 AND thread_id > $2\n                ORDER BY thread_id ASC\n                LIMIT $3",
