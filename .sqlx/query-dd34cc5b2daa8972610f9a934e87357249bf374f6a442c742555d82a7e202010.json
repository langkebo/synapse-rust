  "query": "SELECT id AS \"id!\", event_id AS \"event_id!\", room_id AS \"room_id!\", reporter_user_id AS \"reporter_user_id!\", reported_user_id AS \"reported_user_id?\", event_json AS \"event_json?\", reason AS \"reason?\", description AS \"description?\", status AS \"status!\", score AS \"score!\", received_ts AS \"received_ts!\", resolved_at AS \"resolved_ts?\", resolved_by AS \"resolved_by?\", resolution_reason AS \"resolution_reason?\" FROM event_reports WHERE status = $1 ORDER BY score DESC, received_ts DESC, id DESC LIMIT $2",
