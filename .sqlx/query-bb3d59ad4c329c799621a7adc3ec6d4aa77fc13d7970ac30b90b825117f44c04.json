  "query": "SELECT id as \"id!\", room_id as \"room_id!\", user_id as \"user_id!\",\n                      display_name as \"display_name?\", avatar_url as \"avatar_url?\",\n                      membership as \"membership!\", is_hero as \"is_hero!\",\n                      last_active_ts as \"last_active_ts?\", updated_ts as \"updated_ts!\", created_ts as \"created_ts!\"\n               FROM room_summary_members\n               WHERE room_id = $1 AND membership = 'join'\n               ORDER BY last_active_ts DESC NULLS LAST, updated_ts DESC, user_id ASC\n               LIMIT $2",
