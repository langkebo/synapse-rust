{
  "db_name": "PostgreSQL",
  "query": "SELECT media_id, content_type, file_name, size, uploader_user_id, created_ts, last_accessed_at, quarantine_status\n               FROM media_metadata\n               WHERE ($1::BIGINT IS NULL AND $2::TEXT IS NULL)\n                  OR created_ts < $1\n                  OR (created_ts = $1 AND media_id < $2)\n               ORDER BY created_ts DESC, media_id DESC\n               LIMIT $3",
