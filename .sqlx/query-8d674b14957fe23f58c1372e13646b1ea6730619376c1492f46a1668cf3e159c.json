{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                user_id AS \"user_id!\",\n                username AS \"username!\",\n                COALESCE(displayname, username) AS \"displayname!\",\n                avatar_url AS \"avatar_url?\",\n                created_ts AS \"created_ts!\"\n            FROM users\n            WHERE user_id = $1 AND COALESCE(is_deactivated, FALSE) = FALSE\n            ",
