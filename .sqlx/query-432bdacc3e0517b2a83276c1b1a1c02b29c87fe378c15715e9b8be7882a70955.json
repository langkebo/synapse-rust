  "query": "SELECT id as \"id!\", room_id as \"room_id!\", thread_id as \"thread_id!\", event_id as \"event_id!\", root_event_id as \"root_event_id!\", sender as \"sender!\",\n                       in_reply_to_event_id, content as \"content!\", origin_server_ts as \"origin_server_ts!\", is_edited as \"is_edited!\", is_redacted as \"is_redacted!\", created_ts as \"created_ts!\"\n                FROM thread_replies\n                WHERE room_id = $1 AND thread_id = $2\n                ORDER BY origin_server_ts ASC\n                LIMIT $3",
