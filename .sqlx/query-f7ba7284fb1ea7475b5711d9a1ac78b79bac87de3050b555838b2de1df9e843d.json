  "query": "\n            SELECT\n                id AS \"id!\",\n                token AS \"token!\",\n                user_id AS \"user_id!\",\n                device_id AS \"device_id?\",\n                created_ts AS \"created_ts!\",\n                expires_at AS \"expires_at!\",\n                is_valid AS \"is_valid!\"\n            FROM openid_tokens\n            WHERE user_id = $1\n            ORDER BY created_ts DESC\n            ",
