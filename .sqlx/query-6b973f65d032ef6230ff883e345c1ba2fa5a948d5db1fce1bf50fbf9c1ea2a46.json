  "query": "\n            SELECT\n                id as \"id!\",\n                as_id as \"as_id!\",\n                namespace AS \"namespace_pattern!\",\n                COALESCE(is_exclusive, true) AS \"is_exclusive!\",\n                namespace AS \"regex!\",\n                created_ts as \"created_ts!\"\n            FROM application_service_user_namespaces\n            WHERE as_id = $1\n            ",
