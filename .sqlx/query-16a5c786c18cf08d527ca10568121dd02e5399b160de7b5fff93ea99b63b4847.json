{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT s.space_id as \"space_id!\", s.room_id as \"room_id!\", s.name as \"name?\", s.topic as \"topic?\",\n                   s.avatar_url as \"avatar_url?\", s.creator as \"creator!\", s.join_rule as \"join_rule!\",\n                   s.visibility as \"visibility?\", s.created_ts as \"created_ts!\", s.updated_ts as \"updated_ts?\",\n                   s.is_public as \"is_public!\", s.parent_space_id as \"parent_space_id?\", s.room_type as \"room_type?\"\n            FROM spaces s\n            JOIN space_members sm ON s.space_id = sm.space_id\n            WHERE sm.user_id = $1 AND sm.membership = 'join'\n            ORDER BY s.created_ts DESC\n            ",
