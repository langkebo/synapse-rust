  "query": "\n                SELECT id as \"id!\", name_id as \"name_id!\", user_id as \"user_id!\", issuer as \"issuer!\", first_seen_ts as \"first_seen_ts!\", last_authenticated_ts as \"last_authenticated_ts!\",\n                    COALESCE(authentication_count, 1) as \"authentication_count!\",\n                    COALESCE(attributes, '{}'::jsonb) as \"attributes!\"\n                FROM saml_user_mapping\n                WHERE name_id > $1\n                ORDER BY name_id ASC, issuer ASC\n                LIMIT $2\n                ",
