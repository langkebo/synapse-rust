{
  "db_name": "PostgreSQL",
  "query": "SELECT space_id as \"space_id!\", room_id as \"room_id!\", name as \"name?\", topic as \"topic?\", avatar_url as \"avatar_url?\", creator as \"creator!\", join_rule as \"join_rule!\", visibility as \"visibility?\", created_ts as \"created_ts!\", updated_ts as \"updated_ts?\", is_public as \"is_public!\", parent_space_id as \"parent_space_id?\", room_type as \"room_type?\"\n            FROM spaces\n            WHERE is_public = TRUE\n              AND (($2::BIGINT IS NULL AND $3::TEXT IS NULL)\n                OR created_ts < $2\n                OR (created_ts = $2 AND space_id < $3))\n            ORDER BY created_ts DESC, space_id DESC\n            LIMIT $1",
