  "query": "\n        SELECT event_id AS \"event_id?\", room_id AS \"room_id?\", ts AS \"ts?\", notification_type AS \"notification_type?\", is_read AS \"is_read?\"\n        FROM notifications\n        WHERE user_id = $1\n        ORDER BY ts DESC\n        LIMIT $2\n        ",
