  "query": "\n            SELECT\n                transaction_id AS \"transaction_id!\",\n                from_user AS \"from_user!\",\n                from_device AS \"from_device!\",\n                to_user AS \"to_user!\",\n                to_device,\n                method AS \"method!\",\n                state AS \"state!\",\n                created_ts AS \"created_ts!\",\n                updated_ts\n            FROM verification_requests\n            WHERE to_user = $1 AND state IN ('requested', 'ready', 'pending')\n            ",
