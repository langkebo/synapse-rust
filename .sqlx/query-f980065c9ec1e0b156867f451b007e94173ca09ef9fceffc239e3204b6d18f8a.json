  "query": "\n                    SELECT id as \"id!\", session_id as \"session_id!\", direction as \"direction!\", message_type as \"message_type!\", content as \"content!\", created_ts as \"created_ts!\"\n                    FROM rendezvous_messages\n                    WHERE session_id = $1 AND id > $2\n                    ORDER BY id ASC\n                    ",
