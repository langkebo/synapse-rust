  "query": "SELECT\n                id AS \"id!\",\n                user_id AS \"user_id!\",\n                device_id AS \"device_id?\",\n                event_type AS \"event_type!\",\n                event_data AS \"event_data?\",\n                ip_address AS \"ip_address?\",\n                user_agent AS \"user_agent?\",\n                created_ts AS \"created_ts!\"\n            FROM e2ee_security_events\n            WHERE user_id = $1\n            ORDER BY created_ts DESC\n            LIMIT $2",
