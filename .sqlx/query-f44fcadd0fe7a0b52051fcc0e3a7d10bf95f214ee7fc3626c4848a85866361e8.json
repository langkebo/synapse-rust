{
  "db_name": "PostgreSQL",
  "query": "SELECT id as \"id!\", user_id, event_id, content, sent_ts as \"sent_ts!\"\n             FROM server_notices\n             WHERE ($1::BIGINT IS NULL AND $2::BIGINT IS NULL)\n                OR sent_ts < $1\n                OR (sent_ts = $1 AND id < $2)\n             ORDER BY sent_ts DESC, id DESC\n             LIMIT $3",
