  "query": "\n            SELECT\n                request_id,\n                user_id,\n                device_id,\n                room_id,\n                session_id,\n                algorithm,\n                action,\n                created_ts,\n                COALESCE(is_fulfilled, FALSE) AS \"is_fulfilled!\",\n                fulfilled_by_device AS \"fulfilled_by_device?\",\n                fulfilled_ts AS \"fulfilled_ts?\"\n            FROM e2ee_key_requests\n            WHERE request_id = $1\n            ",
