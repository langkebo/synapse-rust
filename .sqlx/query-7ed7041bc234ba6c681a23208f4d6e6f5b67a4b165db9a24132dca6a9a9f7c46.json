  "query": "\n            INSERT INTO user_notification_status (user_id, notification_id)\n            VALUES ($1, $2)\n            ON CONFLICT (user_id, notification_id) DO NOTHING\n            RETURNING id as \"id!\", user_id as \"user_id!\", notification_id as \"notification_id!\",\n                      is_read as \"is_read!\", is_dismissed as \"is_dismissed!\",\n                      read_ts as \"read_ts?\", dismissed_ts as \"dismissed_ts?\", created_ts as \"created_ts!\"\n            ",
