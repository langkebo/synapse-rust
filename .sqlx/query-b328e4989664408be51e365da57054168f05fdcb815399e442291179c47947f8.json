  "query": "\n            UPDATE room_summaries\n            SET canonical_alias = $2,\n                updated_ts = $3\n            WHERE room_id = $1\n            RETURNING id as \"id?\", room_id as \"room_id!\", room_type as \"room_type?\", name as \"name?\",\n                      topic as \"topic?\", avatar_url as \"avatar_url?\", canonical_alias as \"canonical_alias?\",\n                      join_rules as \"join_rule!\", history_visibility as \"history_visibility!\",\n                      guest_access as \"guest_access!\", is_direct as \"is_direct!\", is_space as \"is_space!\",\n                      is_encrypted as \"is_encrypted!\", member_count as \"member_count!\",\n                      joined_member_count as \"joined_member_count!\", invited_member_count as \"invited_member_count!\",\n                      hero_users as \"hero_users!\", last_event_id as \"last_event_id?\",\n                      last_event_ts as \"last_event_ts?\", last_message_ts as \"last_message_ts?\",\n                      unread_notifications as \"unread_notifications!\", unread_highlight as \"unread_highlight!\",\n                      updated_ts as \"updated_ts?\", created_ts as \"created_ts?\"\n            ",
