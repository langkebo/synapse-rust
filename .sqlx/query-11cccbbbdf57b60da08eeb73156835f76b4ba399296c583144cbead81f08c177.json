{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT id AS \"id!\", event_id AS \"event_id!\", room_id AS \"room_id!\", reporter_user_id AS \"reporter_user_id!\", reported_user_id AS \"reported_user_id?\", event_json AS \"event_json?\", reason AS \"reason?\", description AS \"description?\", status AS \"status!\", score AS \"score!\", received_ts AS \"received_ts!\", resolved_at AS \"resolved_ts?\", resolved_by AS \"resolved_by?\", resolution_reason AS \"resolution_reason?\" FROM event_reports\n                WHERE status = $1 AND (\n                    score < $3 OR\n                    (score = $3 AND received_ts < $4) OR\n                    (score = $3 AND received_ts = $4 AND id < $5)\n                )\n                ORDER BY score DESC, received_ts DESC, id DESC LIMIT $2\n                ",
