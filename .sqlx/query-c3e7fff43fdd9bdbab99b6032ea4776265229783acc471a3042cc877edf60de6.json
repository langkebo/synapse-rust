  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                user_id,\n                device_id,\n                algorithm,\n                key_id,\n                public_key,\n                signatures AS \"signatures?\",\n                display_name,\n                added_ts AS \"added_ts!\",\n                ts_updated_ms AS \"ts_updated_ms?\",\n                key_data AS \"key_data?\",\n                is_fallback AS \"is_fallback?\"\n            FROM device_keys\n            WHERE user_id = $1 AND device_id = $2 AND algorithm = $3\n            LIMIT 1\n            ",
