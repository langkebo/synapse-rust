  "query": "\n            SELECT stream_id, sender_user_id, sender_device_id, event_type, content, message_id\n            FROM to_device_messages\n            WHERE recipient_user_id = $1\n              AND recipient_device_id = $2\n              AND stream_id > $3\n            ORDER BY stream_id ASC\n            LIMIT $4\n            ",
