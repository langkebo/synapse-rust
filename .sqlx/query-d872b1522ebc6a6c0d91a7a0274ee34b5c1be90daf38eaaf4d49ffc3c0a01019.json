  "query": "\n            SELECT id, user_id, provider, config, is_active AS \"is_active!\", created_ts, updated_ts\n            FROM ai_connections\n            WHERE user_id = $1 AND provider = $2 AND is_active = true\n            ORDER BY created_ts DESC\n            LIMIT 1\n            ",
