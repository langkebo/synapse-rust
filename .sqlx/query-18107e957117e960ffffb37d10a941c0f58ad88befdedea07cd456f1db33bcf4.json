{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT event_type AS \"event_type!\", user_id AS \"user_id!\", content AS \"content!\"\n            FROM room_ephemeral\n            WHERE room_id = $1\n            AND (expires_at IS NULL OR expires_at > $2)\n            ORDER BY stream_id DESC\n            LIMIT $3\n            ",
