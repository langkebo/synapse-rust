  "db_name": "PostgreSQL",
  "query": "\n            SELECT id as \"id!\", room_id as \"room_id!\", event_id as \"event_id!\",\n                      event_type as \"event_type!\", state_key as \"state_key?\",\n                      priority as \"priority!\", status as \"status!\",\n                      created_ts as \"created_ts!\", processed_ts as \"processed_ts?\",\n                      error_message as \"error_message?\", retry_count as \"retry_count!\"\n            FROM room_summary_update_queue\n            WHERE status = 'pending'\n            ORDER BY priority DESC, created_ts ASC, id ASC\n            LIMIT $1\n            FOR UPDATE SKIP LOCKED\n            ",
