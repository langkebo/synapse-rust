{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id as \"id!\", session_id as \"session_id!\", user_id as \"user_id!\",\n                COALESCE(name_id, '') as \"name_id!\",\n                COALESCE(issuer, '') as \"issuer!\",\n                COALESCE(session_index, '') as \"session_index!\",\n                COALESCE(attributes, '{}'::jsonb) as \"attributes!\",\n                created_ts as \"created_ts!\", expires_at as \"expires_at!\", last_used_ts as \"last_used_ts!\",\n                COALESCE(status, 'active') as \"status!\"\n            FROM saml_sessions\n            WHERE user_id = $1 AND status = 'active' AND expires_at > $2\n            ORDER BY created_ts DESC\n            LIMIT 1\n            ",
