  "query": "\n            SELECT id as \"id!\", destination as \"destination!\", event_id as \"event_id!\", event_type as \"event_type!\", room_id, content as \"content!\", created_ts as \"created_ts!\", sent_at, retry_count as \"retry_count!\", status as \"status!\"\n            FROM federation_queue\n            WHERE destination = $1 AND status = 'pending'\n            ORDER BY created_ts ASC\n            LIMIT $2\n            ",
