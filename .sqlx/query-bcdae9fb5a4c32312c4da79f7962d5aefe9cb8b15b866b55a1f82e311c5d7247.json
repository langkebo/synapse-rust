  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                user_id AS \"user_id!\",\n                COALESCE(backup_id_text, version::text) AS \"backup_id!\",\n                version AS \"version!\",\n                algorithm AS \"algorithm!\",\n                auth_key AS \"auth_key!\",\n                mgmt_key AS \"mgmt_key!\",\n                auth_data AS \"backup_data!\",\n                etag\n            FROM key_backups\n            WHERE user_id = $1 AND version = $2\n            ",
