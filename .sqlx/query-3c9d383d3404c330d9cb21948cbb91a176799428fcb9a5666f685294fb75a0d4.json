{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id as \"id!\", session_id, user_id, name_id, issuer,\n                event_type as \"event_type!\", status as \"status!\",\n                error_message, ip_address, user_agent, request_id,\n                COALESCE(attributes, '{}'::jsonb) as \"attributes!\",\n                created_ts as \"created_ts!\"\n            FROM saml_auth_events\n            WHERE user_id = $1\n            ORDER BY created_ts DESC\n            LIMIT $2\n            ",
