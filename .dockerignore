# 临时文件
*.tmp
*.bak
*.orig

# 日志
logs/
*.log

# 环境文件
.env
.env.local
.env.*.local

# Docker 文件 (不需要复制到镜像)
# docker/
docker-compose*
.dockerignore

# 其他
.DS_Store
Thumbs.db
