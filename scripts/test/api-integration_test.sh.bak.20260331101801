echo "7. Room Sync Filter"
http_json GET "$SERVER_URL/_matrix/client/v3/sync?filter=%7B%22room%22%3A%7B%22rooms%22%3A%5B%22$ROOM_ID%22%5D%7D%7D" "$TOKEN"
