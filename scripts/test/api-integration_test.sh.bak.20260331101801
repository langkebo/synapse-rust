    DL_STATUS=$(curl -s -o "$MEDIA_DOWNLOAD_FILE" -w "%{http_code}" "$SERVER_URL/_matrix/media/v3/download/$MEDIA_SERVER/$MEDIA_ID" -H "Authorization: Bearer $TOKEN")
