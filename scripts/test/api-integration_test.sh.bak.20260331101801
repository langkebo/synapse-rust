                -H "Content-Type: application/json" \
                -d "{\"type\": \"m.login.password\", \"user\": \"$TEST_USER\", \"password\": \"$TEST_PASS\"}")
            TOKEN=$(json_get "$LOGIN_RESP" "access_token")
