server_name: "${SERVER_NAME}"

server:
  name: "${SERVER_NAME}"
  host: "0.0.0.0"
  port: 28008
  http_port: 28008
  https_port: 8448
  bind_address: "0.0.0.0"
  public_baseurl: "${PUBLIC_BASEURL}"
  signing_key_path: "/app/data/signing.key"
  macaroon_secret_key: "${MACAROON_SECRET_KEY}"
  form_secret: "${FORM_SECRET}"
  registration_shared_secret: "${REGISTRATION_SHARED_SECRET}"
  max_upload_size: 104857600
  max_image_resolution: 1920
  enable_registration: false
  enable_registration_captcha: false
  background_tasks_interval: 3600
  dehydrated_device_cleanup_interval_secs: 3600
  expire_access_token: false
  expire_access_token_lifetime: 86400
  refresh_token_lifetime: 604800
  refresh_token_sliding_window_size: 2592000
  session_duration: 86400
  warmup_pool: true
  # Media storage path. Override via SYNAPSE__SERVER__MEDIA_PATH env var.
  # Default: ./data/media
  # media_path: "./data/media"
  # Megolm encryption key path. Override via
  # SYNAPSE__SERVER__MEGOLM_ENCRYPTION_KEY_PATH env var.
  # If unset, an ephemeral key is generated and encrypted megolm
  # sessions will be unreadable after restart.
  # megolm_encryption_key_path: "/app/data/megolm.key"
  # Whether to start the burn-after-read processor (default true).
  # Override via SYNAPSE__SERVER__ENABLE_BURN_AFTER_READ_PROCESSOR env var.
  # enable_burn_after_read_processor: true
  # Refresh token TTL in seconds used by RefreshTokenService (default 2592000 = 30d).
  # refresh_token_ttl_secs: 2592000

database:
  host: "${DB_HOST}"
  port: 5432
  username: "${DB_USER}"
  password: "${DB_PASSWORD}"
  name: "${DB_NAME}"
  pool_size: 10
  max_size: 50
  min_idle: 5
  connection_timeout: 30

redis:
  host: "${REDIS_HOST}"
  port: 6379
  password: "${REDIS_PASSWORD:-}"
  key_prefix: "synapse:"
  pool_size: 10
  enabled: true
  connection_timeout_ms: 5000
  command_timeout_ms: 3000

logging:
  level: "info"
  format: "text"

federation:
  enabled: true
  allow_ingress: true
  server_name: "${SERVER_NAME}"
  federation_port: 8448
  connection_pool_size: 100
  max_transaction_payload: 10485760
  # Max events accumulated before flushing an outbound federation transaction
  # (default 100).
  # event_broadcast_batch_size: 100

# Search service configuration.
# search:
#   enabled: false
#   provider: "postgres"            # postgres | elasticsearch
#   elasticsearch_url: "http://localhost:9200"
#   # Index name for Postgres FTS or Elasticsearch (default "synapse_search").
#   # search_index_name: "synapse_search"

# Translation service configuration
# When disabled (enabled: false), the translate endpoint returns the original text (passthrough mode).
# Supported providers: google, deepl, libretranslate
translate:
  enabled: false
  # provider: "google"              # google | deepl | libretranslate
  # api_key: "${TRANSLATE_API_KEY}" # API key for the translation provider
  # api_url: ""                     # Optional: override the default API base URL
  # default_target_lang: "en"       # Default target language when client doesn't specify
  # cache_ttl_secs: 86400           # Translation cache TTL in seconds (default: 24h)
  # timeout_secs: 10                # HTTP request timeout for translation API calls
  # max_text_length: 5000           # Maximum text length per translation request
